# ── PostgreSQL ──────────────────────────────────────────────────────────────
POSTGRES_PASSWORD=changeme_strong_password_here

# ── NextAuth ────────────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=replace_with_openssl_rand_base64_32
NEXTAUTH_URL=http://localhost:3000

# ── Microsoft Entra ID (Azure AD) SSO ───────────────────────────────────────
# Steps:
#   1. Go to https://portal.azure.com → Azure Active Directory → App registrations
#   2. New registration → Name: "Yango Deli Promo" → Supported: Single tenant
#   3. Redirect URI: Web → http://localhost:3000/api/auth/callback/azure-ad
#   4. Certificates & secrets → New client secret → copy value below
#   5. Overview page → copy Application (client) ID and Directory (tenant) ID
AZURE_AD_CLIENT_ID=your-application-client-id-here
AZURE_AD_CLIENT_SECRET=your-client-secret-value-here
AZURE_AD_TENANT_ID=your-directory-tenant-id-here

# ── Internal service authentication ─────────────────────────────────────────
# Shared HMAC secret between Next.js and Python API (never exposed to browser)
# Generate with: openssl rand -hex 32
PYTHON_INTERNAL_SECRET=replace_with_openssl_rand_hex_32

# ── Auto-admin assignment ────────────────────────────────────────────────────
# Comma-separated emails that automatically get 'admin' role on first login
ADMIN_EMAILS=admin@yourcompany.com

# ── Recruitment website lead intake ──────────────────────────────────────────
# Shared secret for the public webhook POST /api/recruitment/webhook.
# The recruitment website sends this as the X-Webhook-Secret header
# (its CRM_WEBHOOK_SECRET must be identical to this value).
# Generate with: openssl rand -hex 32
RECRUITMENT_WEBHOOK_SECRET=replace_with_openssl_rand_hex_32
