generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")       // Supabase pooled connection (PgBouncer)
  directUrl = env("DIRECT_URL")         // Supabase direct connection (for migrations)
}

enum Role {
  admin
  manager
  analyst
  viewer
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id                String                 @id @default(cuid())
  name              String?
  email             String                 @unique
  emailVerified     DateTime?
  image             String?
  role              Role                   @default(viewer)
  isActive          Boolean                @default(true)
  accounts          Account[]
  sessions          Session[]
  runs              SimulationRun[]
  settings          UserSettings?
  dashboardLayout   UserDashboardLayout?
  shortcuts         UserShortcut[]
  widgetConfigs     UserWidgetConfig[]
  announcements     CompanyAnnouncement[]  // authored announcements
  integrations      UserIntegration[]
  createdAt         DateTime               @default(now())
  updatedAt         DateTime               @updatedAt
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model SimulationRun {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  fileName  String
  config    Json
  summary   Json
  createdAt DateTime @default(now())
}

model UserSettings {
  id                 String   @id @default(cuid())
  userId             String   @unique
  user               User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  language           String   @default("he")    // "he" | "en" | "ru"
  theme              String   @default("light") // "light" | "dark" | "system"
  background         String?                     // e.g. "color:#f8fafc" | "image:https://..." | "gradient:linear-gradient(...)"
  aiMode             String   @default("secure") // "secure" | "external"
  searchPreference   String   @default("internal") // "internal" | "google"
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
}

model UserDashboardLayout {
  id        String   @id @default(cuid())
  userId    String   @unique
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  layout    Json
  updatedAt DateTime @updatedAt
}

model UserShortcut {
  id           String   @id @default(cuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title        String
  url          String
  icon         String?
  color        String?
  openInNewTab Boolean  @default(false)
  position     Int      @default(0)
  isVisible    Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model UserWidgetConfig {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  widgetKey String
  position  Int
  size      String   @default("medium")  // "small" | "medium" | "large" | "full"
  config    Json?
  isVisible Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  @@unique([userId, widgetKey])
}

model CompanyAnnouncement {
  id          String    @id @default(cuid())
  title       String
  body        String    @db.Text
  authorId    String
  author      User      @relation(fields: [authorId], references: [id])
  isPinned    Boolean   @default(false)
  targetRoles String[]
  expiresAt   DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model UserIntegration {
  id            String   @id @default(cuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  provider      String   // "microsoft", "google", "slack", etc. Microsoft auto-synced via Entra SSO
  connected     Boolean  @default(true)
  metadata      Json?    // e.g. { services: ["mail", "planner", "calendar"] }
  lastSyncedAt  DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model AiProviderConfig {
  id          String   @id @default(cuid())
  provider    String   // "openai", "grok", "azure-openai", "internal-secure-proxy"
  apiKey      String?  @db.Text
  endpoint    String?
  isEnabled   Boolean  @default(true)
  isSecure    Boolean  @default(false) // true = "Secure AI" option
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model SystemConfig {
  key   String @id
  value Json
  // Used for admin-managed feature flags, enabled widgets, etc.
  // Example key: "enabledWidgets" value: ["outlook_mail", "shortcuts", "iframe"]
}
