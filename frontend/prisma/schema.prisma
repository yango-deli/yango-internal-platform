generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")       // Supabase pooled connection (PgBouncer)
  directUrl = env("DIRECT_URL")         // Supabase direct connection (for migrations)
}

enum Role {
  admin
  manager
  analyst
  viewer
}

// ─── NextAuth Models ─────────────────────────────────────────────

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id                String                 @id @default(cuid())
  name              String?
  email             String                 @unique
  emailVerified     DateTime?
  image             String?
  role              Role                   @default(viewer)
  isActive          Boolean                @default(true)
  accounts          Account[]
  sessions          Session[]
  runs              SimulationRun[]
  settings          UserSettings?
  dashboardLayout   UserDashboardLayout?
  shortcuts         UserShortcut[]
  widgetConfigs     UserWidgetConfig[]
  announcements     CompanyAnnouncement[]
  integrations      UserIntegration[]
  workerActivities  WorkerActivity[]
  createdAt         DateTime               @default(now())
  updatedAt         DateTime               @updatedAt
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─── Simulation ───────────────────────────────────────────────────

model SimulationRun {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  fileName  String
  config    Json
  summary   Json
  createdAt DateTime @default(now())
}

// ─── Dashboard / UI Personalization ──────────────────────────────

model UserSettings {
  id                 String   @id @default(cuid())
  userId             String   @unique
  user               User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  language           String   @default("he")    // "he" | "en" | "ru"
  theme              String   @default("light") // "light" | "dark" | "system"
  background         String?
  aiMode             String   @default("secure")
  searchPreference   String   @default("internal")
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
}

model UserDashboardLayout {
  id        String   @id @default(cuid())
  userId    String   @unique
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  layout    Json
  updatedAt DateTime @updatedAt
}

model UserShortcut {
  id           String   @id @default(cuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title        String
  url          String
  icon         String?
  color        String?
  openInNewTab Boolean  @default(false)
  position     Int      @default(0)
  isVisible    Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model UserWidgetConfig {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  widgetKey String
  position  Int
  size      String   @default("medium")
  config    Json?
  isVisible Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  @@unique([userId, widgetKey])
}

model CompanyAnnouncement {
  id          String    @id @default(cuid())
  title       String
  body        String    @db.Text
  authorId    String
  author      User      @relation(fields: [authorId], references: [id])
  isPinned    Boolean   @default(false)
  targetRoles String[]
  expiresAt   DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model UserIntegration {
  id            String    @id @default(cuid())
  userId        String
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  provider      String
  connected     Boolean   @default(true)
  metadata      Json?
  lastSyncedAt  DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model AiProviderConfig {
  id          String   @id @default(cuid())
  provider    String
  apiKey      String?  @db.Text
  endpoint    String?
  isEnabled   Boolean  @default(true)
  isSecure    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model SystemConfig {
  key   String @id
  value Json
}

// ─── HR Module ────────────────────────────────────────────────────

enum WorkerStatus {
  active
  inactive
  on_leave
  terminated
}

enum WorkerType {
  office
  store
  courier
}

enum EmploymentType {
  permanent
  temporary
  partial
  contractor
}

enum VehicleType {
  bike
  motorcycle
  car
}

enum MaritalStatus {
  single
  married
  divorced
  separated
  widowed
}

model Worker {
  id                String            @id @default(cuid())

  // Personal
  firstName         String
  lastName          String
  phone             String?
  email             String?           // personal email (not Entra)
  workEmail         String?           // company email
  idNumber          String?           @unique
  dateOfBirth       DateTime?
  address           String?
  city              String?
  maritalStatus     MaritalStatus?
  photoUrl          String?

  // Employment
  employeeNumber    String?           @unique
  positionTitle     String?
  positionDesc      String?           @db.Text
  workerType        WorkerType        @default(office)
  employmentType    EmploymentType    @default(permanent)
  jobScope          Float?            // 0.0 - 100.0 percentage
  departmentId      String?
  department        HrDepartment?     @relation(fields: [departmentId], references: [id])
  storeId           String?
  store             HrStore?          @relation(fields: [storeId], references: [id])
  startDate         DateTime?
  endDate           DateTime?
  leadSource        String?           // where was the candidate sourced

  // Vehicle (couriers)
  vehicleType       VehicleType?
  vehicleNumber     String?

  // Salary (sensitive)
  grossSalary       Float?
  netSalary         Float?
  bankName          String?
  bankBranch        String?
  bankAccount       String?

  // Status
  status            WorkerStatus      @default(active)

  // Soft delete
  deletedAt         DateTime?

  // Relations
  documents         WorkerDocument[]
  equipment         WorkerEquipment[]
  careerHistory     WorkerCareer[]
  activities        WorkerActivity[]

  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt

  @@index([status])
  @@index([workerType])
  @@index([departmentId])
  @@index([deletedAt])
}

model HrDepartment {
  id        String     @id @default(cuid())
  name      String     @unique
  workers   Worker[]
  createdAt DateTime   @default(now())
}

model HrStore {
  id        String     @id @default(cuid())
  name      String     @unique
  address   String?
  workers   Worker[]
  createdAt DateTime   @default(now())
}

// ─── Worker Documents ─────────────────────────────────────────────

enum DocumentType {
  contract
  form101
  id_copy
  nda
  certificate
  vehicle_license
  driving_license
  other
}

model WorkerDocument {
  id            String       @id @default(cuid())
  workerId      String
  worker        Worker       @relation(fields: [workerId], references: [id], onDelete: Cascade)
  type          DocumentType
  label         String?      // custom label, used when type=other
  fileName      String
  fileUrl       String
  mimeType      String
  sizeBytes     Int
  uploadedById  String
  version       Int          @default(1)
  previousId    String?      // points to previous version's id
  deletedAt     DateTime?    // soft delete
  createdAt     DateTime     @default(now())

  @@index([workerId])
  @@index([type])
}

// ─── Worker Equipment ─────────────────────────────────────────────

enum EquipmentStatus {
  assigned
  returned
  lost
}

model WorkerEquipment {
  id            String          @id @default(cuid())
  workerId      String
  worker        Worker          @relation(fields: [workerId], references: [id], onDelete: Cascade)
  name          String
  description   String?
  serialNumber  String?
  assignedDate  DateTime        @default(now())
  returnedDate  DateTime?
  status        EquipmentStatus @default(assigned)
  deletedAt     DateTime?       // soft delete
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
}

// ─── Worker Career History ────────────────────────────────────────

model WorkerCareer {
  id             String    @id @default(cuid())
  workerId       String
  worker         Worker    @relation(fields: [workerId], references: [id], onDelete: Cascade)
  positionTitle  String
  department     String?
  startDate      DateTime
  endDate        DateTime?
  notes          String?   @db.Text
  createdAt      DateTime  @default(now())
}

// ─── Worker Activity Log ──────────────────────────────────────────

model WorkerActivity {
  id          String   @id @default(cuid())
  workerId    String
  worker      Worker   @relation(fields: [workerId], references: [id], onDelete: Cascade)
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  type        String   // "field_update" | "document_upload" | "equipment_assign" | "status_change" | "created" | "deleted"
  description String
  fieldName   String?
  oldValue    String?  @db.Text
  newValue    String?  @db.Text
  metadata    Json?
  createdAt   DateTime @default(now())

  @@index([workerId])
  @@index([createdAt])
}

// ─── HR Field Permissions ─────────────────────────────────────────

model HrFieldPermission {
  id        String   @id @default(cuid())
  role      Role
  fieldKey  String   // e.g. "salary", "bankAccount", "tabs.salary"
  canView   Boolean  @default(true)
  canEdit   Boolean  @default(false)
  updatedAt DateTime @updatedAt

  @@unique([role, fieldKey])
}
