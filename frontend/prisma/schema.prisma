generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")       // Supabase pooled connection (PgBouncer)
  directUrl = env("DIRECT_URL")         // Supabase direct connection (for migrations)
}

enum Role {
  admin
  manager
  analyst
  viewer
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id                String                 @id @default(cuid())
  name              String?
  email             String                 @unique
  emailVerified     DateTime?
  image             String?
  role              Role                   @default(viewer)
  isActive          Boolean                @default(true)
  accounts          Account[]
  sessions          Session[]
  runs              SimulationRun[]
  settings          UserSettings?
  dashboardLayout   UserDashboardLayout?
  shortcuts         UserShortcut[]
  widgetConfigs     UserWidgetConfig[]
  announcements     CompanyAnnouncement[]  // authored announcements
  assignedCandidates Candidate[]           @relation("CandidateAssignee")
  candidateStageChanges CandidateStageHistory[]
  candidateNotes    CandidateNote[]
  candidateActivities CandidateActivity[]
  createdAt         DateTime               @default(now())
  updatedAt         DateTime               @updatedAt
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model SimulationRun {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  fileName  String
  config    Json
  summary   Json
  createdAt DateTime @default(now())
}

model UserSettings {
  id        String   @id @default(cuid())
  userId    String   @unique
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  language  String   @default("he")    // "he" | "en" | "ru"
  theme     String   @default("light") // "light" | "dark" | "system"
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model UserDashboardLayout {
  id        String   @id @default(cuid())
  userId    String   @unique
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  layout    Json
  updatedAt DateTime @updatedAt
}

model UserShortcut {
  id           String   @id @default(cuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title        String
  url          String
  icon         String?
  color        String?
  openInNewTab Boolean  @default(false)
  position     Int      @default(0)
  isVisible    Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model UserWidgetConfig {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  widgetKey String
  position  Int
  size      String   @default("medium")  // "small" | "medium" | "large" | "full"
  config    Json?
  isVisible Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  @@unique([userId, widgetKey])
}

model CompanyAnnouncement {
  id          String    @id @default(cuid())
  title       String
  body        String    @db.Text
  authorId    String
  author      User      @relation(fields: [authorId], references: [id])
  isPinned    Boolean   @default(false)
  targetRoles String[]
  expiresAt   DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model RecruitmentPosition {
  id          String      @id @default(cuid())
  title       String
  department  String?
  description String?     @db.Text
  isActive    Boolean     @default(true)
  createdAt   DateTime    @default(now())
  candidates  Candidate[]
}

model Candidate {
  id            String   @id @default(cuid())
  firstName     String
  lastName      String
  phone         String
  email         String?
  idNumber      String?
  source        String
  sourceDetail  String?
  positionId    String?
  position      RecruitmentPosition? @relation(fields: [positionId], references: [id])
  workerType    String?
  city          String?
  vehicleType   String?
  stage         String   @default("new")
  stageHistory  CandidateStageHistory[]
  isDuplicate   Boolean  @default(false)
  duplicateOfId String?
  assignedToId  String?
  assignedTo    User?    @relation("CandidateAssignee", fields: [assignedToId], references: [id])
  notes         CandidateNote[]
  activities    CandidateActivity[]
  formData      Json?
  tags          String[]
  isArchived    Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model CandidateStageHistory {
  id          String    @id @default(cuid())
  candidateId String
  candidate   Candidate @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  fromStage   String
  toStage     String
  changedById String
  changedBy   User      @relation(fields: [changedById], references: [id])
  reason      String?
  createdAt   DateTime  @default(now())
}

model CandidateNote {
  id          String    @id @default(cuid())
  candidateId String
  candidate   Candidate @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  authorId    String
  author      User      @relation(fields: [authorId], references: [id])
  content     String    @db.Text
  isPinned    Boolean   @default(false)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model CandidateActivity {
  id          String    @id @default(cuid())
  candidateId String
  candidate   Candidate @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  userId      String
  user        User      @relation(fields: [userId], references: [id])
  type        String
  description String
  metadata    Json?
  createdAt   DateTime  @default(now())
}
